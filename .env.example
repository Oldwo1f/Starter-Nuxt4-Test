# =============================================================================
# Nuna Heritage - Configuration (copier vers .env et remplir les valeurs)
# Fichier unique à la racine : utilisé par backend, frontend, mcp-admin, docker
# =============================================================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nunaheritage
DB_PASSWORD=
DB_NAME=nunaheritage

# JWT
JWT_SECRET=changez-moi-en-production

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEOHI_PRICE_ID=
STRIPE_UMETE_PRICE_ID=

# Brevo
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=

# Frontend (NUXT_PUBLIC_*)
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001
NUXT_PUBLIC_FACEBOOK_APP_ID=
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# MCP Admin (Cursor)
NUNA_API_URL=http://localhost:3001
NUNA_ADMIN_EMAIL=
NUNA_ADMIN_PASSWORD=
